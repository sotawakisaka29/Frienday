rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isGroupMember(groupId) {
      return signedIn()
        && exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid));
    }

    function isGroupOwner(groupId) {
      return signedIn()
        && get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == "owner";
    }

    match /users/{userId} {
      allow read, create, update, delete: if isSelf(userId);

      match /groups/{groupId} {
        allow read, create, update, delete: if isSelf(userId);
      }
    }

    match /publicProfiles/{userId} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update: if isSelf(userId)
        && !request.resource.data.keys().hasAny(["email", "birthYear"]);
      allow delete: if isSelf(userId);
    }

    match /privateProfiles/{userId} {
      allow read, create, update, delete: if isSelf(userId);
    }

    match /groups/{groupId} {
      allow get: if isGroupMember(groupId);
      allow list: if false;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isGroupOwner(groupId);
      allow delete: if isGroupOwner(groupId);

      match /members/{userId} {
        allow get: if isSelf(userId) || isGroupMember(groupId);
        allow list: if isGroupMember(groupId);
        allow create: if signedIn() && (
          userId == request.auth.uid || isGroupOwner(groupId)
        ) && request.resource.data.role in ["owner", "member"];
        allow update: if isSelf(userId)
          && request.resource.data.role == resource.data.role;
        allow delete: if isSelf(userId) || isGroupOwner(groupId);
      }
    }

    match /inviteCodes/{inviteCode} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/inviteCodes/$(inviteCode))
        && request.resource.data.groupId is string
        && getAfter(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.ownerId == request.auth.uid
        && getAfter(/databases/$(database)/documents/groups/$(request.resource.data.groupId)).data.inviteCode == inviteCode;
      allow update: if false;
      allow delete: if signedIn()
        && get(/databases/$(database)/documents/groups/$(resource.data.groupId)).data.ownerId == request.auth.uid;
    }
  }
}
